  "dependencies": {
    "@mpstack/schema": "workspace:*",
    "@mpstack/ui": "workspace:*",
    "@tarojs/components": "^3.6.0",
    "@tarojs/helper": "^3.6.0",
    "@tarojs/plugin-framework-react": "^3.6.0",
    "@tarojs/plugin-platform-weapp": "^3.6.0",
    "@tarojs/react": "^3.6.0",
    "@tarojs/runtime": "^3.6.0",
    "@tarojs/shared": "^3.6.0",
    "@tarojs/taro": "^3.6.0",
    "@tarojs/webpack5-runner": "^3.6.0",
    "react": "^18.3.0",
    "react-dom": "^18.3.0"
  },
  "devDependencies": {
    "@tarojs/cli": "^3.6.0",
    "@types/react": "^18.3.0",
    "babel-preset-taro": "^3.6.0",
    "sass": "^1.69.0",
    "typescript": "^5.7.0",
    "webpack": "^5.91.0"
